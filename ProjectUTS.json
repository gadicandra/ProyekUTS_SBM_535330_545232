        "func": "msg.payload = {\n    \"variablelist\": [\n        {\n            \"address\": \"0x20000317\",\n            \"type\": 1,\n            \"value\": \"1\"\n        }\n    ],\n    \"accesspoint\": 0\n}\n\nmsg.topic = \"write\"\n\nreturn msg;",
