    },
    {
        "id": "efe02ce0920c1c18",
        "type": "function",
        "z": "7b9ed63e.2138f8",
        "name": "function 3",
        "func": "let varName = msg.payload.variablename;\nlet dataArray = msg.payload.variabledata;\n\nif (!dataArray || dataArray.length === 0) return null;\n\n// Ekstrak dan paksa konversi nilai terbaru menjadi Angka (Number)\n// Ini akan menyelesaikan masalah Chart, Temperature, dan Humidity yang gagal masuk ke Gauge\nlet latestValue = Number(dataArray[dataArray.length - 1].y);\n\n// 1. Simpan nilai ke flow memory\nflow.set(varName, latestValue);\n\n// 2. Tarik semua data dari flow memory (pastikan default ke 0 dan bertipe Number)\nlet state = Number(flow.get(\"state\")) || 0;\nlet shift_idx = Number(flow.get(\"shift_idx\")) || 0;\nlet adc = Number(flow.get(\"adc_val\")) || 0;\nlet gauge_val = Number(flow.get(\"gauge_val\")) || 0;\nlet temp = Number(flow.get(\"temperature\")) || 0;\nlet hum = Number(flow.get(\"humidity\")) || 0;\n\nlet button_int = Number(flow.get(\"button_interrupted\")) || 0;\nlet virtual_int = Number(flow.get(\"virtual_interrupt\")) || 0;\n\n// Siapkan wadah untuk 13 Output yang dikosongkan (null) di awal\nlet msgList = new Array(13).fill(null);\n\n// --------------------------------------------------------\n// 3. ROUTING DATA WIDGET (Output 1 sampai 5)\n// --------------------------------------------------------\nif (varName === \"gauge_val\") {\n    msgList[0] = { payload: latestValue }; // Output 1: Chart (Hanya Increment)\n    msgList[4] = { payload: latestValue }; // Output 5: Gauge Increment\n} \nelse if (varName === \"adc_val\") {\n    msgList[1] = { payload: latestValue }; // Output 2: Gauge Potensiometer\n} \nelse if (varName === \"humidity\") {\n    msgList[2] = { payload: latestValue }; // Output 3: Gauge Humidity\n} \nelse if (varName === \"temperature\") {\n    msgList[3] = { payload: latestValue }; // Output 4: Gauge Temperature\n}\n\n// --------------------------------------------------------\n// 4. LOGIKA LED BERDASARKAN STATE (Output 6 sampai 13)\n// --------------------------------------------------------\nlet leds = [0, 0, 0, 0, 0, 0, 0, 0];\n\nif (button_int === 1 || virtual_int === 1) {\n    leds = [1, 1, 1, 1, 1, 1, 1, 1]; // Semua LED nyala (Interupsi)\n} else {\n    if (state === 0) {\n        if (shift_idx >= 0 && shift_idx < 8) {\n            leds[shift_idx] = 1;\n        }\n    } \n    else if (state === 1) {\n        let leds_on = 0;\n        if (gauge_val > 24) leds_on = 8;\n        else if (gauge_val > 21) leds_on = 7;\n        else if (gauge_val > 17) leds_on = 6;\n        else if (gauge_val > 14) leds_on = 5;\n        else if (gauge_val > 10) leds_on = 4;\n        else if (gauge_val > 7) leds_on = 3;\n        else if (gauge_val > 3) leds_on = 2;\n        else if (gauge_val > 0) leds_on = 1;\n\n        for (let i = 0; i < leds_on; i++) {\n            leds[i] = 1;\n        }\n    } \n    else if (state === 2) {\n        let leds_on = Math.floor((adc * 8) / 4095);\n        for (let i = 0; i < leds_on; i++) {\n            if (i < 8) leds[i] = 1;\n        }\n    } \n    else if (state === 3) {\n        let temp_mask = 0x00;\n        if (temp > 30.0) temp_mask = 0x0F;\n        else if (temp > 28.0) temp_mask = 0x07;\n        else if (temp > 24.0) temp_mask = 0x03;\n        else if (temp > 22.0) temp_mask = 0x01;\n\n        let hum_mask = 0x00;\n        if (hum > 90.0) hum_mask = 0xF0;\n        else if (hum > 76.0) hum_mask = 0xE0;\n        else if (hum > 74.0) hum_mask = 0xC0;\n        else if (hum > 70.0) hum_mask = 0x80;\n\n        let combined_mask = temp_mask | hum_mask;\n\n        for (let i = 0; i < 8; i++) {\n            if ((combined_mask & (1 << i)) !== 0) {\n                leds[i] = 1;\n            }\n        }\n    }\n}\n\n// 5. Masukkan data LED ke Index Array 5-12 (Output Node 6 sampai 13)\nfor (let i = 0; i < 8; i++) {\n    msgList[i + 5] = { payload: leds[i] };\n}\n\nreturn msgList;",
        "outputs": 13,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
