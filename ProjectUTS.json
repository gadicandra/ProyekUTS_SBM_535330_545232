    {
        "id": "300a8acf2b3cab61",
        "type": "function",
        "z": "7b9ed63e.2138f8",
        "name": "function 2",
        "func": "msg.payload = {\n    \"variablelist\": [\n        {\n            \"address\": \"0x20000319\",\n            \"type\": 1,\n            \"value\": \"1\"\n        }\n    ],\n    \"accesspoint\": 0\n}\n\nmsg.topic = \"write\"\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 220,
